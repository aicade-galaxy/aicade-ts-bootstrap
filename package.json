{
  "name": "aicade-ts-bootstrap",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "watch": "chokidar 'src/**/*' -c 'npm run build && cpy dist/ ../web-core/public/' ",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "upload": "node upload.js"
  },
  "dependencies": {
    "aicade-ts-sdk": "file:./aicade-ts-sdk-1.0.1.tgz",
    "dotenv": "^17.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "chokidar-cli": "^3.0.0",
    "cpy-cli": "^6.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
